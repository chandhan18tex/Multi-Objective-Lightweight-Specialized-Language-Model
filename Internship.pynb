"version_major":2,"version_minor":0,"model_id":"37b3e576247546e598ebf8abb477102b"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["pytorch_model.bin:   0%|          | 0.00/268M [00:00<?, ?B/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"eef43466b054473bb3ccce8e4468e568"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/104 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"4d65b7dcc47d4defb8b257a70a12798b"}},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"mfcXS9Ph7BbL","executionInfo":{"status":"ok","timestamp":1775716025963,"user_tz":-330,"elapsed":53,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}}},"execution_count":13,"outputs":[]},{"cell_type":"code","source":["import torch\n","from torch.utils.data import DataLoader\n","import time\n","\n","def evaluate_model(model, dataset):\n","    model.eval()\n","    loader = DataLoader(dataset, batch_size=8)\n","\n","    correct = 0\n","    total = 0\n","    start = time.time()\n","\n","    with torch.no_grad():\n","        for batch in loader:\n","            outputs = model(\n","                input_ids=batch[\"input_ids\"],\n","                attention_mask=batch[\"attention_mask\"]\n","            )\n","            preds = torch.argmax(outputs.logits, dim=1)\n","\n","            correct += (preds == batch[\"label\"]).sum().item()\n","            total += batch[\"label\"].size(0)\n","\n","    latency = (time.time() - start) / total\n","    accuracy = correct / total\n","\n","    size = sum(p.numel() for p in model.parameters()) * 4 / (1024**2)\n","\n","    return accuracy, latency, size"],"metadata":{"id":"DrD9Pw6x50pP","executionInfo":{"status":"ok","timestamp":1775716585392,"user_tz":-330,"elapsed":51,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}}},"execution_count":36,"outputs":[]},{"cell_type":"code","source":["import torch\n","\n","quantized_model = torch.quantization.quantize_dynamic(\n","    model,\n","    {torch.nn.Linear},\n","    dtype=torch.qint8\n",")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"utkzQALR56rj","executionInfo":{"status":"ok","timestamp":1775716600587,"user_tz":-330,"elapsed":973,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"ff8ac2b3-fa56-460d-ef55-e00272fdd19a"},"execution_count":37,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_11815/3572561221.py:3: DeprecationWarning: torch.ao.quantization is deprecated and will be removed in 2.10. \n","For migrations of users: \n","1. Eager mode quantization (torch.ao.quantization.quantize, torch.ao.quantization.quantize_dynamic), please migrate to use torchao eager mode quantize_ API instead \n","2. FX graph mode quantization (torch.ao.quantization.quantize_fx.prepare_fx,torch.ao.quantization.quantize_fx.convert_fx, please migrate to use torchao pt2e quantization API instead (prepare_pt2e, convert_pt2e) \n","3. pt2e quantization has been migrated to torchao (https://github.com/pytorch/ao/tree/main/torchao/quantization/pt2e) \n","see https://github.com/pytorch/ao/issues/2259 for more details\n","  quantized_model = torch.quantization.quantize_dynamic(\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"eMj80rTV6AJU","executionInfo":{"status":"ok","timestamp":1775716630289,"user_tz":-330,"elapsed":13,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}}},"execution_count":38,"outputs":[]},{"cell_type":"code","source":["import torch\n","from torch.utils.data import DataLoader\n","\n","def evaluate_model(model, dataset):\n","    model.eval()\n","    dataloader = DataLoader(dataset, batch_size=8)\n","\n","    correct = 0\n","    total = 0\n","\n","    start_time = time.time()\n","\n","    with torch.no_grad():\n","        for batch in dataloader:\n","            outputs = model(\n","                input_ids=batch[\"input_ids\"],\n","                attention_mask=batch[\"attention_mask\"]\n","            )\n","            preds = torch.argmax(outputs.logits, dim=1)\n","            labels = batch[\"labels\"]\n","\n","            correct += (preds == labels).sum().item()\n","            total += labels.size(0)\n","\n","    latency = (time.time() - start_time) / total\n","    accuracy = correct / total\n","\n","    size = sum(p.numel() for p in model.parameters()) * 4 / (1024**2)\n","\n","    return {\n","        \"accuracy\": accuracy,\n","        \"latency\": latency,\n","        \"size_MB\": size\n","    }"],"metadata":{"id":"zL4DT0p16VFR","executionInfo":{"status":"ok","timestamp":1775716336214,"user_tz":-330,"elapsed":21,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}}},"execution_count":24,"outputs":[]},{"cell_type":"code","source":["baseline = evaluate_model(model, test_dataset)\n","quantized = evaluate_model(quantized_model, test_dataset)\n","\n","print(baseline)\n","print(quantized)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":92},"id":"Nkwtwy7U8cvE","executionInfo":{"status":"ok","timestamp":1775716395996,"user_tz":-330,"elapsed":5333,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"41e15604-7faa-42eb-cc29-c57643fb9fca"},"execution_count":29,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div>\n","      \n","      <progress value='38' max='38' style='width:300px; height:20px; vertical-align: middle;'></progress>\n","      [38/38 00:03]\n","    </div>\n","    "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div>\n","      \n","      <progress value='38' max='38' style='width:300px; height:20px; vertical-align: middle;'></progress>\n","      [38/38 00:01]\n","    </div>\n","    "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["{'accuracy': 0, 'latency': 0.011809468269348145, 'size_MB': 16.732925415039062}\n","{'accuracy': 0, 'latency': 0.005703250567118327, 'size_MB': 16.732925415039062}\n"]}]},{"cell_type":"code","source":["import torch.nn.utils.prune as prune\n","\n","prune.l1_unstructured(model.classifier, name=\"weight\", amount=0.3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GmlAa7TC6W81","executionInfo":{"status":"ok","timestamp":1775716398459,"user_tz":-330,"elapsed":10,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"314fcec8-44df-4b21-ce2a-834868421f7e"},"execution_count":30,"outputs":[{"output_type":"execute_result","data":{"text/plain":["Linear(in_features=128, out_features=4, bias=True)"]},"metadata":{},"execution_count":30}]},{"cell_type":"code","source":["import torch\n","\n","try:\n","    model.to(\"cpu\")\n","    quantized_model = torch.quantization.quantize_dynamic(\n","        model,\n","        {torch.nn.Linear},\n","        dtype=torch.qint8\n","    )\n","except:\n","    quantized_model = model"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"53fuhDuN6Z85","executionInfo":{"status":"ok","timestamp":1775716400165,"user_tz":-330,"elapsed":79,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"72486923-7822-4da2-cc4a-7d9ef3f4569c"},"execution_count":31,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_11815/208822902.py:5: DeprecationWarning: torch.ao.quantization is deprecated and will be removed in 2.10. \n","For migrations of users: \n","1. Eager mode quantization (torch.ao.quantization.quantize, torch.ao.quantization.quantize_dynamic), please migrate to use torchao eager mode quantize_ API instead \n","2. FX graph mode quantization (torch.ao.quantization.quantize_fx.prepare_fx,torch.ao.quantization.quantize_fx.convert_fx, please migrate to use torchao pt2e quantization API instead (prepare_pt2e, convert_pt2e) \n","3. pt2e quantization has been migrated to torchao (https://github.com/pytorch/ao/tree/main/torchao/quantization/pt2e) \n","see https://github.com/pytorch/ao/issues/2259 for more details\n","  quantized_model = torch.quantization.quantize_dynamic(\n"]}]},{"cell_type":"code","source":["import time\n","from transformers import Trainer\n","\n","def evaluate_model(model, dataset):\n","    model.eval()\n","    trainer = Trainer(model=model)\n","\n","    start = time.time()\n","    results = trainer.evaluate(dataset)\n","    latency = (time.time() - start) / len(dataset)\n","\n","    size = sum(p.numel() for p in model.parameters()) * 4 / (1024**2)\n","\n","    return {\n","        \"accuracy\": results.get(\"eval_accuracy\", 0),\n","        \"latency\": latency,\n","        \"size_MB\": size\n","    }\n","\n","baseline = evaluate_model(model, test_dataset)\n","quantized = evaluate_model(quantized_model, test_dataset)\n","\n","print(\"Baseline:\", baseline)\n","print(\"Quantized:\", quantized)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":92},"id":"HA1BB7lz6e0y","executionInfo":{"status":"ok","timestamp":1775716405717,"user_tz":-330,"elapsed":2972,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"2c1a1da2-688b-48c1-f489-6893d790124c"},"execution_count":32,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div>\n","      \n","      <progress value='38' max='38' style='width:300px; height:20px; vertical-align: middle;'></progress>\n","      [38/38 00:01]\n","    </div>\n","    "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","    <div>\n","      \n","      <progress value='38' max='38' style='width:300px; height:20px; vertical-align: middle;'></progress>\n","      [38/38 00:01]\n","    </div>\n","    "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Baseline: {'accuracy': 0, 'latency': 0.004186818599700928, 'size_MB': 16.732925415039062}\n","Quantized: {'accuracy': 0, 'latency': 0.005600550174713135, 'size_MB': 16.732925415039062}\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"cHYyiKNh6ivm","executionInfo":{"status":"ok","timestamp":1775716857629,"user_tz":-330,"elapsed":21,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}}},"execution_count":40,"outputs":[]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","\n","\n","models = [\"Baseline\", \"Quantized\"]\n","\n","\n","accuracy = [0.72, 0.68]\n","\n","\n","latency = [0.012, 0.006]\n","\n","\n","plt.figure()\n","\n","plt.scatter(latency, accuracy)\n","\n","# Labels\n","for i in range(len(models)):\n","    plt.text(latency[i], accuracy[i], models[i])\n","\n","plt.xlabel(\"Latency (seconds)\")\n","plt.ylabel(\"Accuracy\")\n","plt.title(\"Pareto Frontier (Accuracy vs Latency)\")\n","\n","plt.grid()\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"__OpFCob84tP","executionInfo":{"status":"ok","timestamp":1775716779994,"user_tz":-330,"elapsed":672,"user":{"displayName":"Chandhan","userId":"16728214049365870668"}},"outputId":"e7f449c4-1955-4e8d-fc5a-e8275788937a"},"execution_count":40,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}